rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isDocOwner() {
      return isAuthenticated() && request.auth.uid == resource.data.uid;
    }

    function isRequestOwner() {
      return isAuthenticated() && request.auth.uid == request.resource.data.uid;
    }

    function isAdmin() {
      return isAuthenticated() && 
        ((request.auth.token.email == "chasetomseth@gmail.com" && request.auth.token.email_verified == true) ||
         (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'));
    }

    // ===============================================================
    // Domain Validators
    // ===============================================================
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'name', 'email']) &&
             data.uid is string &&
             data.name is string && data.name.size() < 100 &&
             data.email is string;
    }

    function isValidDailyLog(data) {
      return data.keys().hasAll(['uid', 'date']) &&
             data.uid is string &&
             data.date is string;
    }

    function isValidWorkoutSession(data) {
      return data.keys().hasAll(['uid', 'date']) &&
             data.uid is string &&
             data.date is string;
    }

    function isValidBodyMetric(data) {
      return data.keys().hasAll(['uid', 'date', 'weightKg']) &&
             data.uid is string &&
             data.date is string &&
             data.weightKg is number;
    }

    function isValidAchievement(data) {
      return data.keys().hasAll(['uid', 'achievementId', 'name', 'earnedAt']) &&
             data.uid is string &&
             data.achievementId is string &&
             data.name is string &&
             data.earnedAt is string;
    }

    function isValidTrainingProgram(data) {
      return data.keys().hasAll(['uid', 'programName', 'status']) &&
             data.uid is string &&
             data.programName is string &&
             data.status is string;
    }

    function isValidCoachConversation(data) {
      return data.keys().hasAll(['uid', 'date', 'messages']) &&
             data.uid is string &&
             data.date is string &&
             data.messages is list;
    }

    function isValidExercisePerformance(data) {
      return data.keys().hasAll(['uid', 'sessionId', 'exerciseId', 'exerciseName', 'sets']) &&
             data.uid is string &&
             data.sessionId is string &&
             data.exerciseId is string &&
             data.exerciseName is string &&
             data.sets is list;
    }

    function isValidWeeklyAdaptation(data) {
      return data.keys().hasAll(['uid', 'date']) &&
             data.uid is string &&
             data.date is string;
    }

    function isValidDailyWorkoutState(data) {
      return data.keys().hasAll(['id', 'uid', 'date', 'status', 'programId']) &&
             data.id is string &&
             data.uid is string &&
             data.date is string &&
             data.status in ['scheduled', 'in-progress', 'completed', 'skipped', 'rest', 'assigned', 'generated'] &&
             data.programId is string;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isOwner(userId) && isValidUser(request.resource.data);
      allow update: if isOwner(userId) && isValidUser(request.resource.data);

      match /achievements/{achievementId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidAchievement(request.resource.data);
        allow update: if isOwner(userId) && isValidAchievement(request.resource.data);
      }

      match /training_programs/{programId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidTrainingProgram(request.resource.data);
        allow update: if isOwner(userId) && isValidTrainingProgram(request.resource.data);
      }

      match /daily_logs/{logId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidDailyLog(request.resource.data);
        allow update: if isOwner(userId) && isValidDailyLog(request.resource.data);
      }

      match /workout_sessions/{sessionId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidWorkoutSession(request.resource.data);
        allow update: if isOwner(userId) && isValidWorkoutSession(request.resource.data);

        match /performance/{performanceId} {
          allow read: if isOwner(userId) || isAdmin();
          allow create: if isOwner(userId) && isValidExercisePerformance(request.resource.data);
          allow update: if isOwner(userId) && isValidExercisePerformance(request.resource.data);
        }
      }

      match /body_metrics/{metricId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidBodyMetric(request.resource.data);
        allow update: if isOwner(userId) && isValidBodyMetric(request.resource.data);
      }

      match /coach_conversations/{conversationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidCoachConversation(request.resource.data);
        allow update: if isOwner(userId) && isValidCoachConversation(request.resource.data);
      }

      match /daily_workout_states/{date} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidDailyWorkoutState(request.resource.data);
        allow update: if isOwner(userId) && isValidDailyWorkoutState(request.resource.data);
      }

      match /weekly_adaptations/{adaptationId} {
        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidWeeklyAdaptation(request.resource.data);
        allow update: if isOwner(userId) && isValidWeeklyAdaptation(request.resource.data);
      }
    }

    match /exercise_library/{exerciseId} {
      allow read: if true; // Publicly readable
      allow write: if isAdmin();
    }
  }
}
